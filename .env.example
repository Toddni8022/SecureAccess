# SecureAccess Environment Variables
# Copy this file to .env and configure as needed

# Database path (optional, defaults to OS-standard app data directory)
# SECUREACCESS_DB_PATH=/path/to/secureaccess.db

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Application theme (dark, light, system)
APP_THEME=dark

# Display server for Docker/headless (Linux only)
DISPLAY=:0
